# --- Casper ---
CASPER_RPC_URL=https://node.testnet.cspr.cloud/rpc
CASPER_CHAIN_NAME=casper-test
AGENT_KEY_PEM=./secret/agent_key.pem
# 64-char contract hashes (no "hash-" prefix) from your contract deploy
ATTESTATION_LOG_HASH=
RWA_VAULT_HASH=
REPUTATION_REGISTRY_HASH=
CASPER_PAYMENT_MOTES=5000000000

# --- x402 premium signal (the agent pays this counterparty) ---
SIGNAL_URL=http://localhost:8402/alpha

# --- Venice (reasoning; OpenAI-compatible) ---
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
# any chat model id from https://venice.ai (e.g. qwen-3-7-max, deepseek-v4-pro,
# zai-org-glm-5-2, claude-opus-4-8). Reasoning + JSON-friendly default below.
VENICE_MODEL=qwen-3-7-max

# --- Real RWA data sources (optional; missing keys degrade that field to null) ---
EIA_API_KEY=
METALS_API_KEY=
CSPR_CLOUD_KEY=

# --- Loop / thresholds ---
CYCLE_MS=60000
CONFIDENCE_THRESHOLD=0.7
# Run N cycles then exit (0 = forever). Handy for demos: MAX_CYCLES=1
MAX_CYCLES=0
# DRY_RUN=true logs on-chain submissions instead of sending them. Leave blank to
# auto-enable whenever the 3 contract hashes above are empty (pre-deploy demo).
DRY_RUN=

# --- Optional: IPFS pin of full reasoning blob ---
WEB3_STORAGE_TOKEN=

# --- Optional: Telegram escalation ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
