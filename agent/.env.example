CASPER_CHAIN_NAME=casper-test
AGENT_KEY_PEM=
ATTESTATION_LOG_HASH=365913a7a26d3e50798c2c0ce31d0850b8b24b2e1a641f990e41f7ad219a6532
RWA_VAULT_HASH=8558283443dfceba9956eadc241401a78fbbeaf2410f6094581d135ecf5923dd
REPUTATION_REGISTRY_HASH=265ebc7dc27997529587517c8a6cc502fd187f163fefe4d3e0946ba10438669c
CASPER_PAYMENT_MOTES=5000000000

# --- x402 premium signal ---
SIGNAL_URL=http://localhost:8402/alpha

# --- Venice (reasoning) — key filled ---
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=deepseek-v4-flash

# --- RWA data sources (keys filled) ---
EIA_API_KEY=
METALS_API_KEY=
# CSPR.cloud token (key "amanah" from console.cspr.build)
CSPR_CLOUD_KEY=

# --- Loop / thresholds ---
CYCLE_MS=60000
CONFIDENCE_THRESHOLD=0.7

WEB3_STORAGE_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PINATA_JWT=
AUDITOR_LOG_HASH=ec0721feef72482e745e8950f57fb17def15a51dda382f31de0004e886b1bf89
AUDITOR_QUORUM_HASH=
ZK_RESERVES_HASH=
POLICY_VERSION=
POLICY_APPROVED_BY=
ACCOUNTABLE_OWNER=
AUDITOR_QUORUM_INSTANCE_ID=

# C2 model diversity: the independent auditor uses a DIFFERENT model family from the actor.
AUDITOR_MODEL=llama-3.3-70b
# C4 simulation/paper mode: run the full pipeline but replace on-chain execution with a
# price-exposed paper fill (nothing touches the chain). Writes web/public/simulation.json.
SIMULATE=false
