# All optional. With none set, the app serves the built-in mock data (lib/mock.ts).
# Set the CSPR.cloud key AND at least NEXT_PUBLIC_VAULT_HASH to flip to live reads.

# --- CSPR.cloud REST (server-side only; the key must never reach the browser) ---
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_BASE=https://api.testnet.cspr.cloud
# Currency id for the CSPR rate endpoint (/rates/{id}/latest). "1" assumed = USD.
CSPR_CLOUD_RATE_CURRENCY=1

# --- Deployed contract hashes (gate the live path; public is fine, they're on-chain) ---
NEXT_PUBLIC_VAULT_HASH=
NEXT_PUBLIC_ATTESTATION_HASH=
NEXT_PUBLIC_REPUTATION_HASH=
# x402 PaymentToken package hash (shows payment settlements in audit trail).
# Default is the deployed hash — only override after a redeploy.
NEXT_PUBLIC_X402_HASH=d784f72c17d143cd96e8bcd2b19fc893f003c1ce9ea29f059eb033bcbd347d79

# ReputationRegistry "state" dict seed — enables the live reputation score on /agent.
# Server-side only. Discover via: cd agent && npx tsx src/find-state-seeds.ts
REPUTATION_STATE_SEED=65a90d00ef950ce780370b0b2bb054f93c7b8431534b1fc30808222d7b1e5bb7

# SpendGate "state" dict seed — enables live guardrail limits (cap/tx, daily limit,
# spent today) on /dashboard + /agent. Server-side only.
SPENDGATE_STATE_SEED=88254c6145e73b973982e335ca2f55a181b7144d58a030732099b4532fa6feab

# ComplianceRegistry "state" dict seed — enables live KYC status + allowlist on the
# dashboard compliance card. Server-side only.
COMPLIANCE_STATE_SEED=273a2df883a8762478d7ccc9e2670e40567ae7f843f9081fb8a2e8d817d2c51a

# CSPR.click wallet app id (the /connect page). 'csprclick-template' works on
# localhost; get your own at console.cspr.build for a deployed domain.
NEXT_PUBLIC_CSPR_CLICK_APP_ID=csprclick-template

# CSPR.cloud Streaming API (WebSocket) — powers the live contract-event feed on
# /dashboard via the SSE relay at /api/stream. Uses CSPR_CLOUD_API_KEY for auth.
CSPR_CLOUD_STREAM_BASE=wss://streaming.testnet.cspr.cloud
# Contract HASHES (not package hashes) the stream filters by. Defaults baked into
# app/api/stream/route.ts; override only after a redeploy.
VAULT_CONTRACT_HASH=15785924492b910a8e42d759ff4c684631fe367858d5bde14f13ecf71ec63a50
ATTESTATION_CONTRACT_HASH=c214ac3fe6c8f832eefd8ff6d7ed6afe9fb7a11b6048fa0a77ffc04fd874f003
REPUTATION_CONTRACT_HASH=fb503979069fec873bcde40182bbe14578f159c18e4513606bb48de9ad15069e
