# Amanah MCP — live on-chain reads. Without these, getVaultState/getAuditTrail
# return a "set env" placeholder (the server still starts).

# RwaVault "state" dictionary seed uref addr (hex) — enables live treasury decode.
# From the vault install effects (amanah/.env.deployed). Update if the vault redeploys.
VAULT_STATE_SEED=

# ReputationRegistry "state" dict seed uref addr (hex) — enables live score reads.
# Find it: query the Casper node for the reputation contract entity named keys
# (use info_get_entity with EntityHash = contract hash at REPUTATION_REGISTRY_HASH),
# then read the "state" URef address and paste it here.
REPUTATION_STATE_SEED=
# Casper testnet JSON-RPC (vault state reads)
CASPER_RPC_URL=https://node.testnet.casper.network/rpc

# CSPR.cloud (audit trail = recent deploys for our contracts)
CSPR_CLOUD_BASE=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=

# Deployed package hashes (defaults baked into chain.ts; override only on redeploy)
RWA_VAULT_HASH=438118a13b5cdcaed1f3cd72bbdcbb3347cd38d2a0d98d2beaa2993a16233347
ATTESTATION_HASH=365913a7a26d3e50798c2c0ce31d0850b8b24b2e1a641f990e41f7ad219a6532
PAYMENT_TOKEN_HASH=d784f72c17d143cd96e8bcd2b19fc893f003c1ce9ea29f059eb033bcbd347d79
